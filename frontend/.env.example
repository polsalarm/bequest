# WalletConnect / Reown project id (free at cloud.reown.com).
# Enables Freighter mobile + LOBSTR + others from Android Chrome (keeps the
# user in Chrome so Web NFC still works). Leave blank to use extension wallets only.
VITE_WALLETCONNECT_PROJECT_ID=

# Stellar network — testnet (default for development)
VITE_STELLAR_NETWORK=testnet
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployed contract IDs (Testnet — Phase 4)
VITE_FACTORY_CONTRACT_ID=CAMKUFDTTIVDL4Z2UV6UISUDGSONOCCEZHTYH3EFTIA2ILSLLKV4F5RH
# Vault token — native XLM SAC on testnet for now; swap to a USDC SAC later
VITE_TOKEN_SAC_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# PDAX fiat rails (server-only — never expose to client)
PDAX_MOCK=true
PDAX_API_KEY=
PDAX_API_SECRET=
PDAX_BASE_URL=https://api.pdax.ph
